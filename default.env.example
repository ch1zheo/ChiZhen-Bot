# Переименуйте этот файл в .env и заполните реальными значениями.
# Файл .env НЕ должен попадать в систему контроля версий (добавьте в .gitignore).

# Токен Telegram-бота, полученный от @BotFather
BOT_TOKEN=TOKEN

# API-ключ Groq (получить на https://console.groq.com/keys)
GROQ_API_KEY=API_KEY

# (Необязательно) Название модели Groq. По умолчанию используется openai/gpt-oss-120b
GROQ_MODEL=openai/gpt-oss-120b
